{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Distribution of Health Facilities in KL-Selangor",
    "subtitle": "1 square represents 1% of health facilities in the KL-Selangor area",
    "anchor": "start",
    "fontSize": 16
  },
  "width": 450,
  "height": 450,
  "data": {
    "url": "data/hotosm_mys_health_facilities_points_geojson.geojson",
    "format": {"type": "json", "property": "features"}
  },
  "transform": [
    {
      "calculate": "datum.properties.healthcare",
      "as": "hc"
    },
    {
      "calculate": "datum.properties.name || ''",
      "as": "name"
    },
    {
      "calculate": "if(datum.hc == 'hospital', test(/Pantai|KPJ|Gleneagles|Columbia|Prince Court|Sunway|Medical Centre|Specialist|Pakar|KPMC|Andorra|Metro|Umra|Tawakal|IHEAL/i, datum.name) ? 'Private Hospital' : 'Government Hospital', 'Clinic')",
      "as": "category"
    },
    {"aggregate": [{"op": "count", "as": "count"}], "groupby": ["category"]},
    {"joinaggregate": [{"op": "sum", "field": "count", "as": "total"}]},
    {
      "calculate": "round((datum.count / datum.total) * 100)",
      "as": "percentage"
    },
    {"calculate": "datum.category + ' (' + datum.percentage + '%)'", "as": "legend_label"},
    {"calculate": "sequence(0, datum.percentage)", "as": "seq"},
    {"flatten": ["seq"]},
    {
      "window": [{"op": "row_number", "as": "waffle_index"}]
    },
    {"calculate": "datum.waffle_index - 1", "as": "index"},
    {"calculate": "datum.index % 10", "as": "col"},
    {"calculate": "floor(datum.index / 10)", "as": "row"}
  ],
  "mark": {"type": "rect", "stroke": "white", "strokeWidth": 1},
  "encoding": {
    "x": {"field": "col", "type": "ordinal", "axis": null},
    "y": {"field": "row", "type": "ordinal", "axis": null},
    "color": {
      "field": "legend_label",
      "type": "nominal",
      "scale": {
        "range": ["#4c78a8", "#f58518", "#e45756"]
      },
      "legend": {"title": "Category (Percentage)"}
    }
  },
  "config": {
    "view": {"stroke": null}
  }
}