{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Top 20 Busiest Transit Stations",
    "anchor": "start",
    "fontSize": 16
  },
  "width": 600,
  "height": 400,
  "data": {
    "url": "data/rapidrail_2026_january.csv" 
  },
  "transform": [
    {
        "filter": "datum.destination != 'A0: All Stations'"
    },
    {
      "aggregate": [{"op": "sum", "field": "ridership", "as": "total_ridership"}],
      "groupby": ["destination"]
    },
    {
      "window": [{"op": "rank", "as": "rank"}],
      "sort": [{"field": "total_ridership", "order": "descending"}]
    },
    {"filter": "datum.rank <= 20"}
  ],
  "mark": "bar",
  "encoding": {
    "y": {"field": "destination", "type": "nominal", "title": "Station", "sort": "-x"},
    "x": {"field": "total_ridership", "type": "quantitative", "title": "Total Passengers (Jan 2026)"},
    "color": {"value": "#3498db"},
    "tooltip": [
      {"field": "destination", "type": "nominal"},
      {"field": "total_ridership", "type": "quantitative", "format": ","}
    ]
  }
}